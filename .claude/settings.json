{
  "permissions": {
    "allow": [
      "WebSearch",
      "Read(//c/Users/Ryan/Documents/GitHub/sense-check/**)",
      "Read(//c/Users/Ryan/Documents/GitHub/sense-check/.claude/**)"
    ],
    "additionalDirectories": [
      "C:\\Users\\Ryan\\Documents\\GitHub\\agentic-dev-boilerplate\\.claude\\commands",
      "C:\\Users\\Ryan\\Documents\\GitHub\\sense-check"
    ]
  },
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/session-story.py 2>/dev/null || python .claude/hooks/session-story.py",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/protect-sensitive.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/bash-guard.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/pre-commit-check.py",
            "timeout": 120
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/reinject-conventions.py 2>/dev/null || python .claude/hooks/reinject-conventions.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
